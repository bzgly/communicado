# Anthropic API key — without it the project runs in mock mode (USE_MOCK=1)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (default: claude-opus-4-8)
# CLAUDE_MODEL=claude-haiku-4-5

# Force mock mode on/off regardless of the API key
# USE_MOCK=1

# Telegram bot token (only needed for bot.py)
# BOT_TOKEN=123456:ABC-...
